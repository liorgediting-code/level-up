# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta dev app (create one at https://developers.facebook.com/apps/)
# OAuth callback URL to whitelist in the app:
#   http://localhost:3000/api/meta/oauth/callback
META_APP_ID=
META_APP_SECRET=
# Optional override; defaults to http://localhost:3000/api/meta/oauth/callback
META_OAUTH_REDIRECT=

# Prisma
DATABASE_URL="file:./dev.db"

# Optional. Without it, new-lead notification emails are skipped (lead still saved).
RESEND_API_KEY=
RESEND_FROM=ASTRAL CRM <crm@yourdomain.com>
