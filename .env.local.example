# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta dev app (create one at https://developers.facebook.com/apps/)
# OAuth callback URL to whitelist in the app:
#   http://localhost:3000/api/meta/oauth/callback
META_APP_ID=
META_APP_SECRET=
# Optional override; defaults to http://localhost:3000/api/meta/oauth/callback
META_OAUTH_REDIRECT=

# Prisma / Postgres (Neon on Vercel).
# DATABASE_URL = pooled connection (used by the app at runtime).
# DATABASE_URL_UNPOOLED = direct connection (used by Prisma for migrations).
# Locally: run `vercel env pull .env.local` to fetch these from the Vercel project,
# or paste the Neon connection strings here.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Optional. Without it, new-lead notification emails are skipped (lead still saved).
RESEND_API_KEY=
RESEND_FROM=ASTRAL CRM <crm@yourdomain.com>

# Bearer token expected by /api/sessions* from the live-transcription extension.
# Must match WEBAPP_AUTH_TOKEN in extension/config.js.
LIVE_TRANSCRIBE_TOKEN=

# Deepgram key — used server-side as a fallback for non-Hebrew transcripts.
# Same key as the extension uses for streaming.
DEEPGRAM_API_KEY=

# OpenAI key — primary provider for Hebrew transcription via Whisper API
# (https://platform.openai.com/account/api-keys). Whisper is far more accurate
# in Hebrew than Deepgram. If unset, falls back to Deepgram.
OPENAI_API_KEY=
