generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  status              String   @default("active")
  salesMeetingsTarget Int?
  endedAt             DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  links               ClientLink[]
  payments            Payment[]
  campaigns           ClientCampaign[]
  landingPages        LandingPage[]
  analysisRuns        AnalysisRun[]
  assets              ClientAsset[]
  convertedFromLeads  Lead[] @relation("ClientConvertedFromLead")
  meetings            Meeting[]
  tasks               Task[]
  journeys            Journey[]
  transcriptSessions  TranscriptSession[]
  recordingFolders    RecordingFolder[]
  metricColumns       ClientMetricColumn[]
  metricRows          ClientMetricRow[]
  notes               Note[]
  targets             Target[]
}

model ClientAsset {
  id          String   @id @default(cuid())
  clientId    String
  kind        String   // creative_image | creative_video | brief | note
  label       String
  text        String?  // for kind=brief (pasted text) or kind=note
  filePath    String?  // absolute path under ./uploads, for creative_image/creative_video/brief (file)
  mimeType    String?
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model ClientLink {
  id       String @id @default(cuid())
  clientId String
  label    String
  url      String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Payment {
  id         String   @id @default(cuid())
  clientId   String
  type       String   // closed | paid | owed
  amount     Float
  currency   String   @default("ILS")
  note       String?
  occurredAt DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model MetaConnection {
  id          String   @id @default(cuid())
  fbUserId    String?
  fbUserName  String?
  accessToken String
  expiresAt   DateTime?
  scope       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts MetaAccount[]
}

model MetaAccount {
  id            String    @id // "act_..."
  connectionId  String
  name          String
  currency      String?
  timezoneName  String?
  accountStatus Int?
  businessName  String?
  enabled       Boolean   @default(true)
  lastSyncedAt  DateTime?

  connection MetaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
}

model Campaign {
  id            String   @id // Meta campaign id
  adAccountId   String
  name          String
  status        String?
  objective     String?
  lastSyncedAt  DateTime @default(now())
  isAgencyOwned Boolean  @default(false)

  clients ClientCampaign[]
  stats   CampaignDailyStat[]
  funnels FunnelCampaign[]

  @@index([isAgencyOwned])
}

model ClientCampaign {
  clientId   String
  campaignId String
  attachedAt DateTime @default(now())

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([clientId, campaignId])
  @@index([campaignId])
}

model CampaignDailyStat {
  id                 String   @id @default(cuid())
  campaignId         String
  date               DateTime
  spend              Float    @default(0)
  impressions        Int      @default(0)
  clicks             Int      @default(0)
  ctr                Float    @default(0)
  cpm                Float    @default(0)
  leads              Int      @default(0)
  costPerLead        Float    @default(0)
  conversions        Int      @default(0)
  costPerConversion  Float    @default(0)
  actionsJson        String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([date])
}

model LandingPage {
  id              String   @id @default(cuid())
  clientId        String
  label           String
  sourceType      String   // url | html | image
  sourceUrl       String?
  htmlPath        String?
  imagePath       String?
  screenshotPath  String?
  createdAt       DateTime @default(now())

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  analysisRuns AnalysisRun[]

  @@index([clientId])
}

model AnalysisRun {
  id                String    @id @default(cuid())
  clientId          String
  landingPageId     String?
  campaignIdsJson   String    @default("[]")
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  status            String    @default("running") // running | done | error
  model             String    @default("claude-opus-4-7")
  inputSnapshotJson String    @default("{}")
  outputJson        String?
  errorMessage      String?
  inputTokens       Int       @default(0)
  outputTokens      Int       @default(0)
  cacheReadTokens   Int       @default(0)
  cacheWriteTokens  Int       @default(0)

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  landingPage LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)

  @@index([clientId])
}

model LeadList {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  webhookToken String   @unique
  createdAt    DateTime @default(now())

  leads    Lead[]
  statuses LeadStatus[]
}

model LeadStatus {
  id                  String  @id @default(cuid())
  name                String
  color               String  @default("#64748b")
  order               Int     @default(0)
  isDefault           Boolean @default(false)
  isConvertedTarget   Boolean @default(false)
  listId              String? // null = global
  list                LeadList? @relation(fields: [listId], references: [id], onDelete: Cascade)
  leads               Lead[]

  @@index([listId])
}

model Lead {
  id                 String    @id @default(cuid())
  listId             String
  name               String
  phone              String?
  email              String?
  utmJson            String?   // JSON.stringified {source,medium,campaign,content,term}
  customFieldsJson   String    @default("{}")
  statusId           String
  notes              String    @default("")
  convertedClientId  String?
  firstContactAt     DateTime?
  viewedAt           DateTime?
  createdAt          DateTime  @default(now())

  list             LeadList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  status           LeadStatus  @relation(fields: [statusId], references: [id])
  convertedClient  Client?     @relation("ClientConvertedFromLead", fields: [convertedClientId], references: [id], onDelete: SetNull)
  activities       LeadActivity[]

  @@index([listId])
  @@index([statusId])
  @@index([convertedClientId])
  @@index([viewedAt])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String   // created | status_change | note | converted
  payload   String   @default("{}") // JSON
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model CrmSettings {
  id                String  @id @default("singleton")
  notificationEmail String?
  updatedAt         DateTime @updatedAt
}

model Meeting {
  id          String   @id @default(cuid())
  clientId    String
  title       String
  scheduledAt DateTime?
  status      String   @default("scheduled") // scheduled | held | cancelled | no_show
  attendees   String   @default("")
  notes       String   @default("")
  outcome     String   @default("")
  whatWorked     String   @default("")
  whatToImprove  String   @default("")
  link        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([scheduledAt])
}

model Task {
  id             String    @id @default(cuid())
  clientId       String
  space          String    // sales | marketing
  title          String
  description    String    @default("")
  priority       String    @default("normal") // low | normal | high
  dueDate        DateTime?
  status         String    @default("open")   // open | done
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  linkedStageId  String?   @unique

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  linkedStage  JourneyStage? @relation(fields: [linkedStageId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([clientId, space, status])
  @@index([dueDate])
}

model Journey {
  id                 String   @id @default(cuid())
  clientId           String
  kind               String   // organic | paid
  videoCount         Int
  status             String   @default("active") // active | completed
  currentStageIndex  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  client Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stages JourneyStage[]

  @@unique([clientId, kind])
  @@index([clientId])
}

model JourneyStage {
  id          String   @id @default(cuid())
  journeyId   String
  index       Int
  kind        String   // writing | filming | editing | strategy | ads_writing | ad_filming | creative
  mode        String   // single | per_video
  docLink     String?
  filmingDate DateTime?
  status      String   @default("locked") // locked | active | done
  taskId      String?  @unique

  journey    Journey            @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  task       Task?
  videoItems JourneyVideoItem[]

  @@unique([journeyId, index])
  @@index([journeyId])
}

model JourneyVideoItem {
  id      String    @id @default(cuid())
  stageId String
  index   Int
  done    Boolean   @default(false)
  doneAt  DateTime?

  stage JourneyStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([stageId, index])
}

model TranscriptSession {
  id             String    @id @default(cuid())
  clientId       String?
  folderId       String?
  title          String?
  language       String    @default("he")
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  createdAt      DateTime  @default(now())
  summary        String?
  audioPath      String?   // absolute path to uploaded webm under ./uploads/transcripts
  audioMime      String?
  transcribeStatus String  @default("pending") // pending | transcribing | ready | failed
  transcribeError  String?

  client Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  folder RecordingFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  chunks TranscriptChunk[]

  @@index([clientId])
  @@index([folderId])
  @@index([startedAt])
}

model RecordingFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  clientId  String?
  createdAt DateTime @default(now())

  parent   RecordingFolder?    @relation("FolderParent", fields: [parentId], references: [id], onDelete: SetNull)
  children RecordingFolder[]   @relation("FolderParent")
  client   Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sessions TranscriptSession[]

  @@index([parentId])
  @@index([clientId])
}

model TranscriptChunk {
  id        String   @id @default(cuid())
  sessionId String
  text      String
  isFinal   Boolean  @default(true)
  startMs   Int      @default(0)
  endMs     Int      @default(0)
  speaker   String   @default("other") // user | other
  createdAt DateTime @default(now())

  session TranscriptSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, startMs])
}

model ClientMetricColumn {
  id        String   @id @default(cuid())
  clientId  String
  key       String
  label     String
  unit      String   @default("number")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, key])
  @@index([clientId, sortOrder])
}

model ClientMetricRow {
  id          String   @id @default(cuid())
  clientId    String
  periodMonth DateTime
  leads       Int      @default(0)
  revenue     Int      @default(0)
  customers   Int      @default(0)
  extraJson   String   @default("{}")
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, periodMonth])
  @@index([clientId, periodMonth])
}

model Funnel {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns   FunnelCampaign[]
  columns     FunnelMetricColumn[]
  rows        FunnelMetricRow[]
  notes       Note[]
}

model FunnelCampaign {
  funnelId   String
  campaignId String
  createdAt  DateTime @default(now())

  funnel     Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([funnelId, campaignId])
  @@index([campaignId])
}

model FunnelMetricColumn {
  id        String   @id @default(cuid())
  funnelId  String
  key       String
  label     String
  unit      String   @default("number")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  funnel    Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@unique([funnelId, key])
  @@index([funnelId, sortOrder])
}

model FunnelMetricRow {
  id          String   @id @default(cuid())
  funnelId    String
  periodMonth DateTime
  valuesJson  String   @default("{}")
  updatedAt   DateTime @updatedAt

  funnel      Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@unique([funnelId, periodMonth])
  @@index([funnelId, periodMonth])
}

model Note {
  id        String   @id @default(cuid())
  scope     String
  targetId  String
  body      String
  createdAt DateTime @default(now())

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  funnelId  String?
  funnel    Funnel?  @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@index([scope, targetId, createdAt])
  @@index([clientId])
  @@index([funnelId])
}

model Target {
  id          String   @id @default(cuid())
  periodType  String   // week | month | quarter | year
  periodStart DateTime // normalized start of the period (UTC midnight)
  scope       String   // income | client | metric
  clientId    String?  // set when scope = client
  label       String   // metric / description (e.g. "הכנסות", "לידים", client goal)
  unit        String   @default("number") // number | currency | percent
  targetValue Int      @default(0) // agorot when unit = currency
  actualValue Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([periodType, periodStart])
  @@index([clientId])
}
