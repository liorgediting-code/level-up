{
  "manifest_version": 3,
  "name": "Live Meeting Transcriber",
  "version": "0.1.0",
  "description": "Private extension: captures meeting tab audio, streams to Deepgram for live Hebrew transcription, and posts transcripts to the webapp.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.zoom.us/*",
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Live Meeting Transcriber",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.zoom.us/*",
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pcm-worklet.js", "offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
